#!/usr/bin/env node

import { promises as fs } from 'node:fs';
import os from 'node:os';
import path from 'node:path';
import { createReadStream, existsSync } from 'node:fs';
import { createInterface } from 'node:readline';
import { spawn, execSync } from 'node:child_process';
import net from 'node:net';

const DATA_DIR = path.join(os.homedir(), '.cc-mux');
const PID_FILE = path.join(DATA_DIR, 'proxy.pid');
const DEFAULT_LOG_PATH = path.join(DATA_DIR, 'logs', 'metrics.jsonl');
const USER_CONFIG_PATH = path.join(DATA_DIR, 'config.json');

const args = process.argv.slice(2);
const command = args[0];

function getFlag(name, defaultValue) {
  const index = args.indexOf(name);
  if (index === -1 || index + 1 >= args.length) return defaultValue;
  return args[index + 1];
}

function hasFlag(name) {
  return args.includes(name);
}

// ── Config resolution: --config > ~/.cc-mux/config.json > defaults ──

function resolveConfigPath(explicit) {
  if (explicit) return explicit;
  if (existsSync(USER_CONFIG_PATH)) return USER_CONFIG_PATH;
  return null; // proxy.mjs will use DEFAULT_CONFIG
}

// ── PID management ──

async function writePidFile(pid) {
  await fs.mkdir(DATA_DIR, { recursive: true });
  await fs.writeFile(PID_FILE, String(pid), 'utf8');
}

async function readPidFile() {
  try {
    const pid = parseInt(await fs.readFile(PID_FILE, 'utf8'), 10);
    return Number.isFinite(pid) ? pid : null;
  } catch {
    return null;
  }
}

async function removePidFile() {
  try { await fs.unlink(PID_FILE); } catch {}
}

// ── Port check ──

function isPortInUse(port, host) {
  return new Promise((resolve) => {
    const server = net.createServer();
    server.once('error', (err) => {
      resolve(err.code === 'EADDRINUSE');
    });
    server.once('listening', () => {
      server.close(() => resolve(false));
    });
    server.listen(port, host);
  });
}

// ── Codex CLI check ──

function isOmxInstalled() {
  try {
    execSync('omx version', { stdio: 'ignore' });
    return true;
  } catch {
    return false;
  }
}

function isCodexInstalled() {
  if (isOmxInstalled()) return true;
  try {
    execSync('codex --version', { stdio: 'ignore' });
    return true;
  } catch {
    return false;
  }
}

// ── Commands ──

async function commandStart() {
  const port = parseInt(getFlag('--port', '8080'), 10);
  const host = getFlag('--host', '127.0.0.1');
  const explicitConfig = getFlag('--config', null);
  const configPath = resolveConfigPath(explicitConfig);

  // Port conflict check
  if (await isPortInUse(port, host)) {
    const existingPid = await readPidFile();
    if (existingPid) {
      console.error(`Port ${port} is in use (existing cc-mux PID: ${existingPid}).`);
      console.error(`Run "cc-mux stop" first, or use --port <other>.`);
    } else {
      console.error(`Port ${port} is already in use by another process.`);
      console.error(`Use --port <other> to pick a different port.`);
    }
    process.exit(1);
  }

  const startOptions = { port, host };
  if (configPath) startOptions.configPath = configPath;

  const { startProxyServer } = await import('../src/proxy.mjs');
  const proxy = await startProxyServer(startOptions);

  await writePidFile(process.pid);

  const shadowStatus = proxy.config.shadow?.enabled ? 'enabled' : 'disabled';
  const routingStatus = proxy.config.routing?.enabled ? 'enabled' : 'disabled';
  const cliBackend = isOmxInstalled() ? 'omx' : 'codex';

  console.log(`cc-mux started`);
  console.log(`  Listen:   http://${proxy.host}:${proxy.port}`);
  console.log(`  Backend:  ${cliBackend}`);
  console.log(`  Config:   ${configPath || '(defaults)'}`);
  console.log(`  Shadow:   ${shadowStatus}`);
  console.log(`  Routing:  ${routingStatus}`);
  console.log(`  PID:      ${process.pid}`);
  console.log(`\nUsage:\n  ANTHROPIC_BASE_URL=http://${proxy.host}:${proxy.port} claude`);

  const cleanup = async () => {
    await removePidFile();
    await proxy.shutdown('cli');
  };

  process.on('SIGINT', () => void cleanup().then(() => process.exit(0)));
  process.on('SIGTERM', () => void cleanup().then(() => process.exit(0)));
}

async function commandRun() {
  const port = parseInt(getFlag('--port', '8080'), 10);
  const host = getFlag('--host', '127.0.0.1');
  const explicitConfig = getFlag('--config', null);
  const configPath = resolveConfigPath(explicitConfig);

  if (await isPortInUse(port, host)) {
    console.error(`Port ${port} is already in use. Run "cc-mux stop" first or use --port <other>.`);
    process.exit(1);
  }

  const startOptions = { port, host };
  if (configPath) startOptions.configPath = configPath;

  const { startProxyServer } = await import('../src/proxy.mjs');
  const proxy = await startProxyServer(startOptions);
  await writePidFile(process.pid);

  const baseUrl = `http://${proxy.host}:${proxy.port}`;
  console.log(`cc-mux proxy running on ${baseUrl}`);
  console.log(`Launching Claude Code...\n`);

  const claude = spawn('claude', [], {
    stdio: 'inherit',
    env: { ...process.env, ANTHROPIC_BASE_URL: baseUrl },
  });

  claude.on('error', (err) => {
    if (err.code === 'ENOENT') {
      console.error('\n"claude" command not found. Install Claude Code first:');
      console.error('  npm install -g @anthropic-ai/claude-code');
    } else {
      console.error(`\nFailed to launch Claude Code: ${err.message}`);
    }
  });

  claude.on('close', async (code) => {
    await removePidFile();
    await proxy.shutdown('cli');
    process.exit(code ?? 0);
  });

  const shutdown = () => {
    claude.kill('SIGTERM');
  };
  process.on('SIGINT', shutdown);
  process.on('SIGTERM', shutdown);
}

async function commandInit() {
  await fs.mkdir(DATA_DIR, { recursive: true });

  if (existsSync(USER_CONFIG_PATH)) {
    console.log(`Config already exists: ${USER_CONFIG_PATH}`);
    console.log('Edit it directly or delete to re-initialize.');
    process.exit(0);
  }

  const hasCodex = isCodexInstalled();

  const config = {
    anthropic: {
      base_url: 'https://api.anthropic.com',
      api_key_env: 'ANTHROPIC_API_KEY',
    },
    openai: {
      base_url: 'https://api.openai.com/v1',
      api_key_env: 'OPENAI_API_KEY',
      default_model: 'gpt-5.4',
    },
    shadow: {
      enabled: false,
      target_query_sources: ['agent:custom', 'agent:default', 'compact', 'verification_agent'],
      max_tool_count: 5,
      thinking_enabled: false,
    },
    routing: {
      enabled: false,
      rules: [
        {
          name: 'tool-continuation-to-codex',
          enabled: true,
          target: 'openai',
          model: 'gpt-5.4',
          condition: {
            last_message_tool_result: true,
          },
        },
      ],
    },
    fallback_529: {
      enabled: hasCodex,
      target_query_sources: [],
    },
  };

  await fs.writeFile(USER_CONFIG_PATH, JSON.stringify(config, null, 2) + '\n', 'utf8');
  console.log(`Config created: ${USER_CONFIG_PATH}`);
  console.log(`  Shadow eval: disabled (enable in config for Claude vs Codex comparison)`);
  console.log(`  Routing:     disabled (enable routing.enabled in config for tool-continuation routing)`);
  console.log(`  529 fallback: ${hasCodex ? 'enabled' : 'disabled (install Codex CLI to enable)'}`);
  console.log(`\nStart with:\n  cc-mux run`);
  if (hasCodex) {
    console.log(`\nTo enable Codex routing, edit ${USER_CONFIG_PATH}:`);
    console.log(`  "routing": { "enabled": true }`);
  }
}

async function commandStats() {
  const sessionFilter = getFlag('--session', null);
  const logPath = getFlag('--log', DEFAULT_LOG_PATH);

  let exists = true;
  try { await fs.access(logPath); } catch { exists = false; }
  if (!exists) {
    console.log('No metrics log found. Start the proxy and make some requests first.');
    process.exit(0);
  }

  const sessions = new Map();

  const rl = createInterface({ input: createReadStream(logPath), crlfDelay: Infinity });
  for await (const line of rl) {
    if (!line.trim()) continue;
    try {
      const record = JSON.parse(line);
      const sid = record.session_id || 'unknown';
      if (sessionFilter && sid !== sessionFilter) continue;

      if (!sessions.has(sid)) {
        sessions.set(sid, {
          turns: 0,
          total_input_tokens: 0,
          total_output_tokens: 0,
          cache_hit_sum: 0,
          agent_count: 0,
          retry_count: 0,
          context_growth_sum: 0,
          last_input: null,
          first_ts: record.ts,
          last_ts: record.ts,
        });
      }

      const s = sessions.get(sid);
      s.turns += 1;
      s.total_input_tokens += record.input_tokens || 0;
      s.total_output_tokens += record.output_tokens || 0;
      s.cache_hit_sum += record.cache_hit_rate || 0;
      if (record.is_retry) s.retry_count += 1;
      if (typeof record.query_source === 'string' && record.query_source.startsWith('agent:')) s.agent_count += 1;
      if (s.last_input !== null) s.context_growth_sum += (record.input_tokens || 0) - s.last_input;
      s.last_input = record.input_tokens || 0;
      s.last_ts = record.ts;
    } catch {}
  }

  if (sessions.size === 0) {
    console.log(sessionFilter ? `No data for session: ${sessionFilter}` : 'No metrics recorded yet.');
    process.exit(0);
  }

  for (const [sid, s] of sessions) {
    console.log(`\nSession: ${sid}`);
    console.log(`  Period:              ${s.first_ts} → ${s.last_ts}`);
    console.log(`  Turns:               ${s.turns}`);
    console.log(`  Input tokens:        ${s.total_input_tokens.toLocaleString()}`);
    console.log(`  Output tokens:       ${s.total_output_tokens.toLocaleString()}`);
    console.log(`  Avg cache hit rate:  ${s.turns > 0 ? (s.cache_hit_sum / s.turns * 100).toFixed(1) : 0}%`);
    console.log(`  Agent request ratio: ${s.turns > 0 ? (s.agent_count / s.turns * 100).toFixed(1) : 0}%`);
    console.log(`  Retries:             ${s.retry_count}`);
    console.log(`  Context growth/turn: ${s.turns > 1 ? Math.round(s.context_growth_sum / (s.turns - 1)).toLocaleString() : 'N/A'} tokens`);
  }
}

async function commandStop() {
  const pid = await readPidFile();
  if (!pid) {
    console.log('No running proxy found (no PID file).');
    process.exit(1);
  }

  try {
    process.kill(pid, 'SIGTERM');
    console.log(`Sent SIGTERM to proxy (PID: ${pid}).`);
    await removePidFile();
  } catch (err) {
    if (err.code === 'ESRCH') {
      console.log(`Process ${pid} not found. Cleaning up stale PID file.`);
      await removePidFile();
    } else {
      throw err;
    }
  }
}

async function commandDashboard() {
  const sessionFilter = getFlag('--session', null);
  const logPath = getFlag('--log', DEFAULT_LOG_PATH);
  const fresh = hasFlag('--fresh');
  const lang = getFlag('--lang', 'en');
  const { startDashboard } = await import('../src/dashboard.mjs');
  await startDashboard({ logPath, session: sessionFilter, fresh, lang });
}

async function commandAdvise() {
  const logPath = getFlag('--log', DEFAULT_LOG_PATH);

  let exists = true;
  try { await fs.access(logPath); } catch { exists = false; }
  if (!exists) {
    console.log('No metrics log found. Start the proxy and make some requests first.');
    process.exit(0);
  }

  const { adviseFromLog } = await import('../src/advisor.mjs');
  const result = await adviseFromLog({ logPath });

  for (const line of result.lines) {
    console.log(line);
  }
}

function printUsage() {
  const B = '\x1b[1m';
  const C = '\x1b[36m';
  const D = '\x1b[2m';
  const R = '\x1b[0m';

  console.log(`
${B}cc-mux${R} ${D}— Local observability gateway for Claude Code${R}

${C}Quick Start:${R}
  ${B}cc-mux run${R}              ${D}Start proxy + Claude Code in one command${R}

${C}Commands:${R}
  ${B}cc-mux init${R}             ${D}Create config at ~/.cc-mux/config.json${R}
  ${B}cc-mux start${R}            ${D}Start proxy server (background use)${R}
  ${B}cc-mux run${R}              ${D}Start proxy + launch Claude Code${R}
  ${B}cc-mux stop${R}             ${D}Stop running proxy${R}
  ${B}cc-mux dashboard${R}        ${D}Live metrics dashboard${R}
  ${B}cc-mux stats${R}            ${D}Session statistics${R}
  ${B}cc-mux advise${R}           ${D}Configuration recommendations${R}

${C}Options:${R}
  --port <n>       ${D}Proxy port (default: 8080)${R}
  --host <addr>    ${D}Bind address (default: 127.0.0.1)${R}
  --config <path>  ${D}Config file path${R}
  --fresh          ${D}Dashboard: ignore previous log entries${R}
  --lang <code>    ${D}Dashboard language: en (default), ko${R}
  --session <id>   ${D}Filter by session ID${R}
`);
}

switch (command) {
  case 'start':
    await commandStart();
    break;
  case 'run':
    await commandRun();
    break;
  case 'init':
    await commandInit();
    break;
  case 'stats':
    await commandStats();
    break;
  case 'advise':
    await commandAdvise();
    break;
  case 'dashboard':
    await commandDashboard();
    break;
  case 'stop':
    await commandStop();
    break;
  default:
    printUsage();
    process.exit(command ? 1 : 0);
}
